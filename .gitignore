# ==========================================
# general_agent directory - only keep source folder and run.py
# ==========================================
# Ignore all content under general_agent
general_agent/*
# But keep source folder, run.py, and setup files
!general_agent/source/
!general_agent/source/**
!general_agent/run.py
!general_agent/README.md
!general_agent/.env-example
!general_agent/pyproject.toml
!general_agent/requirements.txt
!general_agent/environment.yml
!general_agent/setup.sh
# Keep WebWalkerQA T³ PoC module
!general_agent/webwalkerqa/
!general_agent/webwalkerqa/**
# Re-exclude pycache within webwalkerqa (negation above would un-ignore it)
general_agent/webwalkerqa/**/__pycache__/
general_agent/webwalkerqa/__pycache__/
# Keep specific data files (benchmark tasks)
!general_agent/data/
!general_agent/data/mathhay_benchmark.json
!general_agent/data/mathhay_documents.json
!general_agent/data/mcpbench_benchmark.json
!general_agent/data/search_benchmark.json
!general_agent/data/swebench_test_50.json
!general_agent/data/tau2bench_benchmark.json
!general_agent/data/terminalbench_benchmark.json
# Keep traces folder (selected traces for publication)
!general_agent/traces/
!general_agent/traces/**
# Keep open-source scripts
!general_agent/scripts/
general_agent/scripts/*
!general_agent/scripts/run_baseline.sh
!general_agent/scripts/run_pairwise_self_choice.sh
!general_agent/scripts/run_parallel_scaling.sh
!general_agent/scripts/run_pointwise_self_choice.sh
!general_agent/scripts/run_sequential_scaling.sh
!general_agent/scripts/README.md
!general_agent/scripts/models.py

# But still exclude cache/compiled artifacts (the !general_agent/source/** above would "un-ignore" them)
general_agent/source/**/__pycache__/
general_agent/source/**/*.py[cod]
general_agent/source/**/*$py.class
